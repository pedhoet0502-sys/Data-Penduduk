{
  "entities": {
    "Resident": {
      "title": "Resident",
      "description": "Data penduduk lengkap",
      "type": "object",
      "properties": {
        "kkNumber": {
          "type": "string",
          "description": "Nomor KK (16 digit)"
        },
        "fullName": {
          "type": "string",
          "description": "Nama Lengkap"
        },
        "nik": {
          "type": "string",
          "description": "NIK (16 digit)"
        },
        "gender": {
          "type": "string",
          "enum": ["Laki-laki", "Perempuan"],
          "description": "Jenis Kelamin"
        },
        "birthPlace": {
          "type": "string",
          "description": "Tempat Lahir"
        },
        "birthDate": {
          "type": "string",
          "format": "date",
          "description": "Tanggal Lahir"
        },
        "religion": {
          "type": "string",
          "description": "Agama"
        },
        "education": {
          "type": "string",
          "description": "Pendidikan"
        },
        "maritalStatus": {
          "type": "string",
          "description": "Status Perkawinan"
        },
        "familyPosition": {
          "type": "string",
          "description": "Status Hubungan dalam Keluarga"
        },
        "occupation": {
          "type": "string",
          "description": "Pekerjaan"
        },
        "bloodType": {
          "type": "string",
          "description": "Golongan Darah"
        },
        "phone": {
          "type": "string",
          "description": "Nomor Telepon"
        },
        "fatherName": {
          "type": "string",
          "description": "Nama Ayah Kandung"
        },
        "motherName": {
          "type": "string",
          "description": "Nama Ibu Kandung"
        },
        "status": {
          "type": "string",
          "enum": ["Aktif", "Meninggal Dunia", "Pindah Domisili", "Tidak Aktif"],
          "description": "Status Keberadaan Penduduk"
        },
        "inactiveDate": {
          "type": "string",
          "description": "Tanggal Non-Aktif (jika meninggal/pindah)"
        },
        "residenceStatus": {
          "type": "string",
          "enum": ["Milik Sendiri", "Sewa/Kontrak", "Menumpang", "Rumah Dinas", "Lainnya"],
          "description": "Status Tempat Tinggal"
        },
        "photoUrl": {
          "type": "string",
          "description": "URL foto profil penduduk"
        },
        "ownerId": {
          "type": "string",
          "description": "UID pemilik data"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["kkNumber", "fullName", "nik", "gender", "birthPlace", "birthDate", "ownerId"]
    },
    "Mutation": {
      "title": "Mutation",
      "description": "Data Mutasi Penduduk",
      "type": "object",
      "properties": {
        "residentId": { "type": "string", "description": "ID Penduduk terkait" },
        "residentName": { "type": "string", "description": "Nama Penduduk" },
        "type": { "type": "string", "enum": ["Kelahiran", "Kematian", "Penduduk Datang", "Penduduk Pindah"] },
        "date": { "type": "string", "description": "Tanggal Peristiwa" },
        "description": { "type": "string", "description": "Keterangan tambahan" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["residentId", "residentName", "type", "date", "ownerId", "createdAt"]
    },
    "Share": {
      "title": "Share",
      "description": "Izin berbagi akses data antarpengguna",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "UID pemilik data yang dibagikan" },
        "ownerEmail": { "type": "string", "description": "Email pemilik data" },
        "collaboratorEmail": { "type": "string", "description": "Email penerima akses" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "ownerEmail", "collaboratorEmail", "createdAt"]
    }
  },
  "firestore": {
    "residents": {
      "schema": { "$ref": "#/entities/Resident" },
      "description": "Koleksi data penduduk"
    },
    "mutations": {
      "schema": { "$ref": "#/entities/Mutation" },
      "description": "Koleksi data mutasi penduduk"
    },
    "shares": {
      "schema": { "$ref": "#/entities/Share" },
      "description": "Koleksi data berbagi akses"
    }
  }
}
