rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-.@]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function currentUserEmail() { return request.auth.token.email.lower(); }

    function isCollaborator(ownerId) {
      return isSignedIn() && exists(/databases/$(database)/documents/shares/$(currentUserEmail() + "_" + ownerId));
    }

    function hasAccess(ownerId) {
      return isOwner(ownerId) || isCollaborator(ownerId);
    }

    // Resident Validation
    function isValidResident(data) {
      return data.keys().hasAll(['kkNumber', 'fullName', 'nik', 'gender', 'ownerId', 'createdAt', 'updatedAt', 'status'])
        // Key count check - relaxed to allow for legacy and new fields
        && data.keys().size() >= 8 && data.keys().size() <= 30
        && data.status in ['Aktif', 'Meninggal Dunia', 'Pindah Domisili', 'Tidak Aktif']
        && data.kkNumber is string && (data.kkNumber.size() == 16 || data.kkNumber.size() == 0)
        && data.fullName is string && data.fullName.size() >= 2
        && data.nik is string && (data.nik.size() == 16 || data.nik.size() == 0)
        && data.gender in ['Laki-laki', 'Perempuan']
        && data.ownerId == request.auth.uid
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        // Optional/Conditional fields check (only if present)
        && (!data.keys().hasAny(['idCardStatus']) || data.idCardStatus in ['Setempat', 'Luar Wilayah'])
        && (!data.keys().hasAny(['residenceStatus']) || data.residenceStatus in ['Milik Sendiri', 'Sewa/Kontrak', 'Menumpang', 'Rumah Dinas', 'Lainnya'])
        && (!data.keys().hasAny(['familyPosition']) || data.familyPosition is string)
        && (!data.keys().hasAny(['religion']) || data.religion is string)
        && (!data.keys().hasAny(['education']) || data.education is string)
        && (!data.keys().hasAny(['maritalStatus']) || data.maritalStatus is string)
        && (!data.keys().hasAny(['occupation']) || data.occupation is string)
        && (!data.keys().hasAny(['bloodType']) || data.bloodType is string)
        && (!data.keys().hasAny(['phone']) || data.phone is string)
        && (!data.keys().hasAny(['fatherName']) || data.fatherName is string)
        && (!data.keys().hasAny(['motherName']) || data.motherName is string)
        && (!data.keys().hasAny(['residencyCategory']) || data.residencyCategory is string)
        && (!data.keys().hasAny(['photoUrl']) || (data.photoUrl is string && data.photoUrl.size() <= 2048))
        && (!data.keys().hasAny(['inactiveDate']) || data.inactiveDate is string);
    }

    // Mutation Validation
    function isValidMutation(data) {
      return data.keys().hasAll(['residentId', 'residentName', 'type', 'date', 'ownerId', 'createdAt'])
        && data.keys().size() >= 6 && data.keys().size() <= 9
        && isValidId(data.residentId)
        && data.type in ['Kelahiran', 'Kematian', 'Penduduk Datang', 'Penduduk Pindah']
        && data.date is string
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 1000))
        && data.ownerId == request.auth.uid
        && data.createdAt is timestamp;
    }

    // Share Validation
    function isValidShare(data) {
      return data.keys().hasAll(['ownerId', 'ownerEmail', 'collaboratorEmail', 'createdAt'])
        && data.keys().size() >= 4 && data.keys().size() <= 6
        && data.ownerId == request.auth.uid
        && data.ownerEmail is string
        && data.collaboratorEmail is string
        && data.collaboratorEmail == data.collaboratorEmail.lower()
        && data.createdAt is timestamp;
    }

    match /residents/{residentId} {
      allow create: if isSignedIn() 
        && isValidId(residentId)
        && isValidResident(incoming())
        && incoming().createdAt == request.time;
      
      allow update: if (isOwner(existing().ownerId) || (!existing().keys().hasAny(['ownerId']) && isSignedIn()))
        && isValidId(residentId)
        && (
          // Action: Full Update / Form Submit
          (isValidResident(incoming()) && 
           (!existing().keys().hasAny(['ownerId']) || incoming().ownerId == existing().ownerId) &&
           (!existing().keys().hasAny(['createdAt']) || incoming().createdAt == existing().createdAt) &&
           incoming().updatedAt == request.time) ||
          // Action: Quick Status Update / Mutation Change
          (incoming().diff(existing()).affectedKeys().hasOnly(['maritalStatus', 'familyPosition', 'status', 'inactiveDate', 'updatedAt']) &&
           incoming().updatedAt == request.time)
        );
      
      allow delete: if isOwner(existing().ownerId);
      
      allow get: if hasAccess(existing().ownerId);
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isCollaborator(resource.data.ownerId));
    }

    match /mutations/{mutationId} {
      allow create: if isSignedIn() 
        && isValidId(mutationId)
        && isValidMutation(incoming())
        && incoming().createdAt == request.time;
      
      allow get: if hasAccess(existing().ownerId);
      allow delete: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isCollaborator(resource.data.ownerId));
    }

    match /shares/{shareId} {
      // shareId should be collaboratorEmail + "_" + ownerId
      allow create: if isSignedIn() 
        && isValidShare(incoming())
        && incoming().createdAt == request.time;
      
      allow update: if isSignedIn()
        && isOwner(existing().ownerId)
        && isValidShare(incoming());

      allow read, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.collaboratorEmail == currentUserEmail());
    }
  }
}
