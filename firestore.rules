rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-.@]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function currentUserEmail() { return request.auth.token.email.lower(); }

    function isCollaborator(ownerId) {
      return isSignedIn() && exists(/databases/$(database)/documents/shares/$(currentUserEmail() + "_" + ownerId));
    }

    function hasAccess(ownerId) {
      return isOwner(ownerId) || isCollaborator(ownerId);
    }

    // Resident Validation
    function isValidResident(data) {
      let requiredFields = ['kkNumber', 'fullName', 'nik', 'gender', 'birthPlace', 'birthDate', 'religion', 'education', 'maritalStatus', 'familyPosition', 'occupation', 'bloodType', 'phone', 'ownerId', 'createdAt', 'updatedAt', 'fatherName', 'motherName', 'status'];
      return data.keys().hasAll(requiredFields)
        // Check if residenceStatus is required
        && (data.familyPosition != 'Kepala Keluarga' || (data.keys().hasAll(['residenceStatus']) && data.residenceStatus in ['Milik Sendiri', 'Sewa/Kontrak', 'Menumpang', 'Rumah Dinas', 'Lainnya']))
        // Allow slightly more keys to be future-proof and handle optional photoUrl and inactiveDate
        && data.keys().size() >= 19 && data.keys().size() <= 23
        && data.status in ['Aktif', 'Meninggal Dunia', 'Pindah Domisili', 'Tidak Aktif']
        && (!data.keys().hasAny(['inactiveDate']) || data.inactiveDate is string)
        && data.kkNumber is string && data.kkNumber.size() == 16
        && data.fullName is string && data.fullName.size() >= 2 && data.fullName.size() <= 200
        && data.nik is string && data.nik.size() == 16
        && data.fatherName is string && data.fatherName.size() >= 2 && data.fatherName.size() <= 200
        && data.motherName is string && data.motherName.size() >= 2 && data.motherName.size() <= 200
        && data.gender in ['Laki-laki', 'Perempuan']
        && data.birthPlace is string && data.birthPlace.size() > 0 && data.birthPlace.size() <= 100
        && data.birthDate is string
        && data.religion is string
        && data.education is string
        && data.maritalStatus is string
        && data.familyPosition is string
        && data.occupation is string
        && data.bloodType is string
        && data.phone is string && data.phone.size() <= 20
        && (!data.keys().hasAny(['photoUrl']) || (data.photoUrl is string && data.photoUrl.size() <= 2048))
        && data.ownerId == request.auth.uid
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Mutation Validation
    function isValidMutation(data) {
      let requiredFields = ['residentId', 'residentName', 'type', 'date', 'ownerId', 'createdAt'];
      return data.keys().hasAll(requiredFields)
        && data.keys().size() >= 6 && data.keys().size() <= 8
        && isValidId(data.residentId)
        && data.type in ['Kelahiran', 'Kematian', 'Penduduk Datang', 'Penduduk Pindah']
        && data.date is string
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 1000))
        && data.ownerId == request.auth.uid
        && data.createdAt is timestamp;
    }

    // Share Validation
    function isValidShare(data) {
      let requiredFields = ['ownerId', 'ownerEmail', 'collaboratorEmail', 'createdAt'];
      return data.keys().hasAll(requiredFields)
        && data.keys().size() == 4
        && data.ownerId == request.auth.uid
        && data.ownerEmail is string
        && data.collaboratorEmail is string
        && data.collaboratorEmail == data.collaboratorEmail.lower()
        && data.createdAt is timestamp;
    }

    match /residents/{residentId} {
      allow create: if isSignedIn() 
        && isValidId(residentId)
        && isValidResident(incoming())
        && incoming().createdAt == request.time;
      
      allow update: if isOwner(existing().ownerId)
        && isValidId(residentId)
        && (
          // Action: Full Update / Form Submit
          (isValidResident(incoming()) && 
           incoming().ownerId == existing().ownerId &&
           incoming().createdAt == existing().createdAt &&
           incoming().updatedAt == request.time) ||
          // Action: Quick Status Update / Mutation Change
          (incoming().diff(existing()).affectedKeys().hasOnly(['maritalStatus', 'familyPosition', 'status', 'inactiveDate', 'updatedAt']) &&
           incoming().updatedAt == request.time)
        );
      
      allow delete: if isOwner(existing().ownerId);
      
      allow get: if hasAccess(existing().ownerId);
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isCollaborator(resource.data.ownerId));
    }

    match /mutations/{mutationId} {
      allow create: if isSignedIn() 
        && isValidId(mutationId)
        && isValidMutation(incoming())
        && incoming().createdAt == request.time;
      
      allow get: if hasAccess(existing().ownerId);
      allow delete: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isCollaborator(resource.data.ownerId));
    }

    match /shares/{shareId} {
      // shareId should be collaboratorEmail + "_" + ownerId
      allow create: if isSignedIn() 
        && isValidShare(incoming())
        && incoming().createdAt == request.time;
      
      allow update: if isSignedIn()
        && isOwner(existing().ownerId)
        && isValidShare(incoming());

      allow read, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.collaboratorEmail == currentUserEmail());
    }
  }
}
